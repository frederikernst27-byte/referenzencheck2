# ==== Google-Scholar-Verifizierung (in dieser Reihenfolge versucht) ====
# 1) SERP API  -> https://serpapi.com
SERPAPI_KEY=
# 2) ScrapingBee (Backup für SERP API) -> https://www.scrapingbee.com
SCRAPINGBEE_KEY=
# 3) ScraperAPI -> https://www.scraperapi.com  (structured/google/scholar)
SCRAPERAPI_KEY=
# 4) SearchApi.io -> https://www.searchapi.io
SEARCHAPI_KEY=
# 5) Scrapingdog -> https://www.scrapingdog.com
SCRAPINGDOG_KEY=

# ==== Metadaten-APIs (kostenlos, kein Key zwingend) ====
# Crossref "polite pool": eigene E-Mail eintragen für bessere Limits
CROSSREF_MAILTO=
# OpenAlex polite pool
OPENALEX_MAILTO=
# Semantic Scholar (optional, hebt Rate-Limits an) -> https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_KEY=

# ==== KI-Parsing & Treffer-Bewertung (DeepSeek via OpenRouter) ====
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Modell-ID auf OpenRouter (Standard: deepseek/deepseek-chat)
OPENROUTER_MODEL=deepseek/deepseek-chat
# Optional: eigenes (ggf. stärkeres) Modell nur fürs Zerlegen/Strukturieren der
# Referenzen. Fallback ist OPENROUTER_MODEL. Empfohlen, wenn das Haupt-Modell ein
# kleines "flash"-Modell ist und Einträge falsch getrennt werden.
OPENROUTER_PARSE_MODEL=
# Optional, nur für OpenRouter-Statistik:
OPENROUTER_SITE_URL=

# ==== Telegram-Bot (optional) ====
# Bot-Token von @BotFather
TELEGRAM_BOT_TOKEN=
# Frei wählbares Geheimnis; sichert den Webhook ab (wird als secret_token gesetzt
# und bei jedem Update über den Header X-Telegram-Bot-Api-Secret-Token geprüft).
TELEGRAM_WEBHOOK_SECRET=

# ==== Speicher für /setkey (optional, Vercel KV / Upstash) ====
# Nötig, damit Bot-Nutzer ihren eigenen OpenRouter-Key dauerhaft hinterlegen können.
# Entweder dieses Namens-Paar (Vercel KV) ...
KV_REST_API_URL=
KV_REST_API_TOKEN=
# ... oder dieses (Upstash direkt):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
